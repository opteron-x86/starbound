{
  "_schema": "starbound.entity_template.factions.v1",
  "_description": "Faction generation templates. Each galaxy generates one faction per category (or rolls for optional categories). Name patterns use slots like {adj}, {noun}, {civ_prefix} filled from component pools. Category determines base traits; components add variation.",

  "generation_rules": {
    "_description": "Which categories to generate. 'guaranteed' always appear. 'optional' have a chance per seed.",
    "guaranteed": ["military", "economic", "guild", "religious", "criminal_frontier"],
    "optional": [
      { "category": "criminal_covert", "chance": 0.8 },
      { "category": "military", "chance": 0.4, "_note": "Second military faction from rival civ" },
      { "category": "economic", "chance": 0.3, "_note": "Competing trade network" }
    ],
    "max_factions": 8
  },

  "categories": {
    "military": {
      "scope": "civ_internal",
      "_scope_note": "Attached to a parent civilization. Uses civ name in faction name.",
      "base_traits": {
        "alignment": 0.8,
        "aggression": 0.7,
        "openness": 0.2,
        "secrecy": 0.3
      },
      "default_services": ["intelligence", "missions"],
      "visibility_range": [0.7, 1.0],

      "name_patterns": [
        "{civ_prefix} Military Command",
        "{civ_prefix} Defense Corps",
        "{civ_prefix} Strategic Command",
        "{civ_prefix} Guard Fleet",
        "{civ_prefix} {mil_suffix}",
        "The {civ_prefix} {mil_suffix}"
      ],

      "components": {
        "mil_suffix": [
          { "name": "War Council", "weight": 0.8, "trait_bias": { "aggression": 0.1 } },
          { "name": "Security Bureau", "weight": 1.0, "trait_bias": { "secrecy": 0.1 } },
          { "name": "Naval Command", "weight": 1.0, "trait_bias": {} },
          { "name": "Frontier Watch", "weight": 0.7, "trait_bias": { "openness": 0.1 } },
          { "name": "Iron Fleet", "weight": 0.6, "trait_bias": { "aggression": 0.15 } },
          { "name": "Sentinel Corps", "weight": 0.8, "trait_bias": { "alignment": 0.1 } }
        ]
      }
    },

    "economic": {
      "scope": "transnational",
      "_scope_note": "Operates across civilization borders. Independent naming.",
      "base_traits": {
        "alignment": 0.5,
        "aggression": 0.2,
