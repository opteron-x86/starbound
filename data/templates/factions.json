      "components": {
        "trade_noun": [
          { "name": "Corridor", "weight": 1.0, "trait_bias": {}, "flavor": ["routes", "logistics"] },
          { "name": "Nexus", "weight": 0.8, "trait_bias": { "openness": 0.1 }, "flavor": ["hub", "central"] },
          { "name": "Meridian", "weight": 0.8, "trait_bias": {}, "flavor": ["crossroads", "established"] },
          { "name": "Void", "weight": 0.7, "trait_bias": { "secrecy": 0.1 }, "flavor": ["deep_space", "frontier_trade"] },
          { "name": "Crucible", "weight": 0.6, "trait_bias": { "aggression": 0.1 }, "flavor": ["competitive", "ruthless"] },
